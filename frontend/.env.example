# Frontend Environment Variables

# Use this to point the frontend to the production backend URL on Render
# VITE_API_URL=https://your-custom-gift-tracker-api.onrender.com/api

# For local development, if VITE_API_URL is omitted, it defaults to:
# VITE_API_URL=http://localhost:5000/api

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=customer-gift-order-tracker
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
